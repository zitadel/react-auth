# -----------------------------------------------------------------------------
# ZITADEL OpenID Connect (OIDC) Configuration
# -----------------------------------------------------------------------------
# This is a client-side single-page application using the Authorization Code
# Flow with PKCE via @zitadel/react-auth. There is NO client secret and NO
# session secret — a PKCE public client needs neither. Every value here is
# safe to expose in the browser bundle, which is why each is prefixed VITE_.

# The full domain URL of your ZITADEL instance (the OIDC issuer / authority).
# Example: https://my-org-a1b2c3.zitadel.cloud
VITE_ZITADEL_DOMAIN="https://your-zitadel-domain"

# The Client ID of your ZITADEL application (a User Agent / SPA app with PKCE).
VITE_ZITADEL_CLIENT_ID="your-zitadel-application-client-id"

# Where ZITADEL redirects after authentication. MUST exactly match a Redirect
# URI configured in your ZITADEL application settings.
VITE_ZITADEL_REDIRECT_URI="http://localhost:3000/auth/callback"

# Where ZITADEL redirects after logout. MUST exactly match a Post Logout
# Redirect URI configured in your ZITADEL application settings.
VITE_ZITADEL_POST_LOGOUT_REDIRECT_URI="http://localhost:3000/auth/logout/callback"

# Space-separated OIDC scopes requested at sign-in.
VITE_ZITADEL_SCOPE="openid profile email"
